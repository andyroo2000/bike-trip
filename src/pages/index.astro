---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

// Read and render the markdown content
const content = await Astro.glob('../content/hokkaido-bike-trip.md');
const Post = content[0];
---

<BaseLayout title="Hokkaido Bike Tour">
  <article class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-a:text-blue-600">
    <Post.Content />
  </article>
</BaseLayout>
