---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Bike Tours">
  <h1 class="text-3xl font-bold tracking-tight mb-8">Trips</h1>
  <div class="grid gap-6 sm:grid-cols-2">
    <a href="/2026/" class="block p-6 border border-border rounded-lg hover:border-accent transition-colors no-underline">
      <h2 class="text-xl font-semibold text-ink m-0">2026 — Hokkaido</h2>
      <p class="text-muted mt-2 mb-0">Shibetsu to Sapporo via Daisetsuzan, Okhotsk coast, and Shiretoko</p>
    </a>
    <a href="/2025/" class="block p-6 border border-border rounded-lg hover:border-accent transition-colors no-underline">
      <h2 class="text-xl font-semibold text-ink m-0">2025 — Japan & Korea</h2>
      <p class="text-muted mt-2 mb-0">Hokkaido coastal route, Tokyo, Seoul</p>
    </a>
  </div>
</BaseLayout>
